# Порт сервера
PORT=3456

# Аутентификация агентов (ключ:agentId)
# steve = тимлид (ставит задачи из Telegram)
# org = главный диспетчер (читает todo, пишет ТЗ, делегирует)
# backend-cto = Марк (backend)
# design-cdo = Джони (UI/UX)
# pasha = Паша (архитектор, пишет спеки)
# critic-audit = аудит безопасности
# qa = тестировщик
AGENTBOARD_API_KEYS=sk-steve-001:steve,sk-org-001:org,sk-backend-cto-001:backend-cto,sk-design-cdo-001:design-cdo,sk-pasha-001:pasha,sk-critic-001:critic-audit,sk-qa-001:qa,sk-dashboard-001:dashboard

# OpenClaw gateway — для wake-уведомлений агентов
# Токен из ~/.openclaw/openclaw.json → gateway.token
OPENCLAW_HOOK_URL=http://localhost:18789/hooks/agent
OPENCLAW_HOOK_TOKEN=bro-weight-hook-2026

# Публичный URL (ngrok)
PUBLIC_URL=https://lemony-lorean-strategically.ngrok-free.dev

# Директория данных
DATA_DIR=./data

# Dashboard PIN protection
DASHBOARD_PIN=1234

# PIN для защиты дашборда
DASHBOARD_PIN=1234
